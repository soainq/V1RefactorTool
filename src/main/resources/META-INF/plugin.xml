<idea-plugin>
    <id>com.internal.project.refactor.assistant</id>
    <name>Internal Project Refactor Assistant</name>
    <vendor>Internal Tooling</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.androidstudio</depends>

    <actions>
        <group id="InternalProjectRefactorAssistant.Group"
               text="Internal Refactor"
               description="Internal refactor preview tools"
               popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="InternalProjectRefactorAssistant.PreviewTemplateRename"
                    class="com.internal.refactorassistant.action.PreviewTemplateRenameAction"
                    text="Preview Template Rename"
                    description="Preview package, Kotlin, and layout rename candidates without modifying files"/>
        </group>
    </actions>
</idea-plugin>
