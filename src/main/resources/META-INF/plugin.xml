<idea-plugin>
    <id>com.internal.project.refactor.assistant</id>
    <name>Internal Project Refactor Assistant</name>
    <vendor>Internal Tooling</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>com.intellij.modules.androidstudio</depends>
    <depends>org.jetbrains.android</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Internal Project Refactor Assistant" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>

    <actions>
        <group id="InternalProjectRefactorAssistant.Group"
               text="Internal Refactor"
               description="Internal template duplication tools"
               popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="InternalProjectRefactorAssistant.DuplicateTemplateProject"
                    class="com.internal.refactorassistant.action.DuplicateTemplateProjectAction"
                    text="Duplicate Template Project"
                    description="Generate and apply a safe refactor plan for duplicating a template Android project"/>
        </group>
    </actions>
</idea-plugin>
